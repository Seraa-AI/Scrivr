{
  "name": "@scrivr/export-markdown",
  "version": "1.0.4",
  "description": "Markdown export for Scrivr documents",
  "type": "module",
  "main": "./dist/index.cjs",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "import": { "types": "./dist/index.d.ts", "default": "./dist/index.js" },
      "require": { "types": "./dist/index.d.cts", "default": "./dist/index.cjs" }
    }
  },
  "files": ["dist"],
  "scripts": {
    "dev": "tsup --watch",
    "build": "tsup",
    "typecheck": "tsc --noEmit",
    "clean": "rm -rf dist"
  },
  "dependencies": {
    "prosemirror-markdown": "^1.13.4"
  },
  "peerDependencies": {
    "@scrivr/core": "workspace:*"
  },
  "devDependencies": {
    "@scrivr/core": "workspace:*",
    "tsup": "^8.0.0",
    "typescript": "^5.4.0"
  }
}
