{
  "name": "@scrivr/core",
  "version": "1.0.5",
  "description": "High-performance canvas-based document editor engine",
  "license": "Apache-2.0",
  "author": "Seraa AI <hello@seraa.ai>",
  "repository": {
    "type": "git",
    "url": "https://github.com/Seraa-AI/Scrivr.git",
    "directory": "packages/core"
  },
  "homepage": "https://github.com/Seraa-AI/Scrivr#readme",
  "bugs": {
    "url": "https://github.com/Seraa-AI/Scrivr/issues"
  },
  "keywords": [
    "canvas",
    "editor",
    "prosemirror",
    "document",
    "rich-text",
    "scrivr"
  ],
  "type": "module",
  "main": "./dist/index.cjs",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "import": {
        "types": "./dist/index.d.ts",
        "default": "./dist/index.js"
      },
      "require": {
        "types": "./dist/index.d.cts",
        "default": "./dist/index.cjs"
      }
    }
  },
  "files": [
    "dist"
  ],
  "publishConfig": {
    "access": "public",
    "provenance": true
  },
  "scripts": {
    "dev": "tsup --watch",
    "build": "tsup",
    "test": "vitest run",
    "test:watch": "vitest",
    "typecheck": "tsc --noEmit",
    "clean": "rm -rf dist"
  },
  "devDependencies": {
    "@types/markdown-it": "^14.1.2",
    "tsup": "^8.0.0",
    "typescript": "^5.4.0"
  },
  "dependencies": {
    "@floating-ui/dom": "^1.7.6",
    "@hocuspocus/provider": "^3.4.4",
    "markdown-it": "^14.1.1",
    "prosemirror-commands": "^1.7.1",
    "prosemirror-history": "^1.5.0",
    "prosemirror-inputrules": "^1.5.1",
    "prosemirror-keymap": "^1.2.3",
    "prosemirror-markdown": "^1.13.4",
    "prosemirror-model": "^1.25.4",
    "prosemirror-schema-list": "^1.5.1",
    "prosemirror-state": "^1.4.4",
    "prosemirror-transform": "^1.11.0",
    "y-prosemirror": "^1.3.7",
    "yjs": "^13.6.30"
  }
}
