{
  "name": "@scrivr/react",
  "version": "1.0.1",
  "description": "React bindings for the Scrivr canvas document editor",
  "license": "Apache-2.0",
  "author": "Seraa AI <hello@seraa.ai>",
  "repository": {
    "type": "git",
    "url": "https://github.com/Seraa-AI/Scrivr.git",
    "directory": "packages/react"
  },
  "homepage": "https://github.com/Seraa-AI/Scrivr#readme",
  "bugs": {
    "url": "https://github.com/Seraa-AI/Scrivr/issues"
  },
  "keywords": [
    "canvas",
    "editor",
    "react",
    "prosemirror",
    "document",
    "rich-text",
    "scrivr"
  ],
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "import": "./dist/index.js",
      "types": "./dist/index.d.ts"
    }
  },
  "files": [
    "dist"
  ],
  "publishConfig": {
    "access": "public",
    "provenance": true
  },
  "scripts": {
    "dev": "tsup --watch",
    "build": "tsup",
    "test": "true",
    "typecheck": "tsc --noEmit",
    "clean": "rm -rf dist"
  },
  "dependencies": {
    "@floating-ui/dom": "^1.7.6"
  },
  "peerDependencies": {
    "@scrivr/core": "workspace:*",
    "@scrivr/plugins": "workspace:*",
    "react": "^18.0.0",
    "react-dom": "^18.0.0"
  },
  "peerDependenciesMeta": {
    "@scrivr/plugins": {
      "optional": true
    }
  },
  "devDependencies": {
    "@scrivr/core": "workspace:*",
    "@scrivr/plugins": "workspace:*",
    "@types/react": "^18.0.0",
    "@types/react-dom": "^18.0.0",
    "tsup": "^8.0.0",
    "typescript": "^5.4.0"
  }
}
