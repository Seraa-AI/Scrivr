{
  "name": "@scrivr/export-docx",
  "version": "0.0.0",
  "description": "DOCX export for Scrivr documents — type-only skeleton, no implementation yet",
  "type": "module",
  "main": "./dist/index.cjs",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "import": { "types": "./dist/index.d.ts", "default": "./dist/index.js" },
      "require": { "types": "./dist/index.d.cts", "default": "./dist/index.cjs" }
    }
  },
  "files": ["dist"],
  "scripts": {
    "dev": "tsup --watch",
    "build": "tsup",
    "typecheck": "tsc --noEmit",
    "clean": "rm -rf dist"
  },
  "peerDependencies": {
    "@scrivr/core": "workspace:*"
  },
  "devDependencies": {
    "@scrivr/core": "workspace:*",
    "prosemirror-model": "^1.25.4",
    "tsup": "^8.0.0",
    "typescript": "^5.4.0"
  }
}
