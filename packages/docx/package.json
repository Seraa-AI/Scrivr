{
  "name": "@scrivr/docx",
  "version": "1.0.13",
  "description": "DOCX import + export for Scrivr documents — semantic round-trip to WordprocessingML",
  "license": "Apache-2.0",
  "author": "Seraa AI <hello@seraa.ai>",
  "repository": {
    "type": "git",
    "url": "https://github.com/Seraa-AI/Scrivr.git",
    "directory": "packages/docx"
  },
  "homepage": "https://github.com/Seraa-AI/Scrivr#readme",
  "bugs": {
    "url": "https://github.com/Seraa-AI/Scrivr/issues"
  },
  "keywords": [
    "docx",
    "word",
    "wordprocessingml",
    "ooxml",
    "import",
    "export",
    "scrivr",
    "prosemirror"
  ],
  "type": "module",
  "main": "./dist/index.cjs",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "import": {
        "types": "./dist/index.d.ts",
        "default": "./dist/index.js"
      },
      "require": {
        "types": "./dist/index.d.cts",
        "default": "./dist/index.cjs"
      }
    }
  },
  "files": [
    "dist"
  ],
  "publishConfig": {
    "access": "public",
    "provenance": true
  },
  "scripts": {
    "dev": "tsup --watch",
    "build": "tsup",
    "test": "vitest run",
    "test:watch": "vitest",
    "typecheck": "tsc --noEmit",
    "clean": "rm -rf dist"
  },
  "dependencies": {
    "fast-xml-parser": "^4.5.0",
    "fflate": "^0.8.2"
  },
  "peerDependencies": {
    "@scrivr/core": "workspace:*"
  },
  "devDependencies": {
    "@scrivr/core": "workspace:*",
    "prosemirror-model": "^1.25.4",
    "tsup": "^8.0.0",
    "typescript": "^5.4.0",
    "vitest": "^2.1.9"
  }
}
