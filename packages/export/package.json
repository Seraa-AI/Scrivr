{
  "name": "@scrivr/export",
  "version": "1.0.4",
  "description": "PDF and Markdown export for Scrivr documents",
  "license": "Apache-2.0",
  "author": "Seraa AI <hello@seraa.ai>",
  "repository": {
    "type": "git",
    "url": "https://github.com/Seraa-AI/Scrivr.git",
    "directory": "packages/export"
  },
  "homepage": "https://github.com/Seraa-AI/Scrivr#readme",
  "bugs": {
    "url": "https://github.com/Seraa-AI/Scrivr/issues"
  },
  "keywords": [
    "canvas",
    "editor",
    "pdf",
    "export",
    "markdown",
    "scrivr"
  ],
  "type": "module",
  "main": "./dist/index.cjs",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "import": {
        "types": "./dist/index.d.ts",
        "default": "./dist/index.js"
      },
      "require": {
        "types": "./dist/index.d.cts",
        "default": "./dist/index.cjs"
      }
    }
  },
  "files": [
    "dist"
  ],
  "publishConfig": {
    "access": "public",
    "provenance": true
  },
  "scripts": {
    "dev": "tsup --watch",
    "build": "tsup",
    "test": "vitest run",
    "test:watch": "vitest",
    "typecheck": "tsc --noEmit",
    "clean": "rm -rf dist"
  },
  "dependencies": {
    "@scrivr/core": "workspace:*",
    "@scrivr/export-pdf": "workspace:*",
    "@scrivr/export-markdown": "workspace:*"
  },
  "devDependencies": {
    "tsup": "^8.0.0",
    "typescript": "^5.4.0",
    "vitest": "^2.1.9"
  }
}
