{
  "name": "@inscribe/export",
  "version": "0.1.0",
  "description": "PDF and Markdown export for Inscribe documents",
  "license": "Apache-2.0",
  "author": "Seraa AI <hello@seraa.ai>",
  "repository": {
    "type": "git",
    "url": "https://github.com/Seraa-AI/Inscribe.git",
    "directory": "packages/export"
  },
  "homepage": "https://github.com/Seraa-AI/Inscribe#readme",
  "bugs": {
    "url": "https://github.com/Seraa-AI/Inscribe/issues"
  },
  "keywords": [
    "canvas",
    "editor",
    "pdf",
    "export",
    "markdown",
    "inscribe"
  ],
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "import": "./dist/index.js",
      "types": "./dist/index.d.ts"
    }
  },
  "files": [
    "dist"
  ],
  "publishConfig": {
    "access": "public",
    "provenance": true
  },
  "scripts": {
    "dev": "tsup --watch",
    "build": "tsup",
    "typecheck": "tsc --noEmit",
    "clean": "rm -rf dist"
  },
  "dependencies": {
    "@inscribe/core": "workspace:*",
    "pdf-lib": "^1.17.1",
    "prosemirror-markdown": "^1.13.4"
  },
  "devDependencies": {
    "tsup": "^8.0.0",
    "typescript": "^5.4.0"
  }
}
