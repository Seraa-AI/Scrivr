{
  "name": "@inscribe/plugins",
  "version": "0.0.1",
  "description": "ProseMirror plugins and collaboration extensions for Inscribe",
  "license": "Apache-2.0",
  "author": "Seraa AI <hello@seraa.ai>",
  "repository": {
    "type": "git",
    "url": "https://github.com/Seraa-AI/Inscribe.git",
    "directory": "packages/plugins"
  },
  "homepage": "https://github.com/Seraa-AI/Inscribe#readme",
  "bugs": {
    "url": "https://github.com/Seraa-AI/Inscribe/issues"
  },
  "keywords": [
    "canvas",
    "editor",
    "prosemirror",
    "plugins",
    "collaboration",
    "yjs",
    "inscribe"
  ],
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "import": "./dist/index.js",
      "types": "./dist/index.d.ts"
    }
  },
  "files": [
    "dist"
  ],
  "publishConfig": {
    "access": "public",
    "provenance": true
  },
  "scripts": {
    "dev": "tsup --watch",
    "build": "tsup",
    "test": "vitest run",
    "test:watch": "vitest",
    "typecheck": "tsc --noEmit",
    "clean": "rm -rf dist"
  },
  "dependencies": {
    "@inscribe/core": "workspace:*"
  },
  "peerDependencies": {
    "@hocuspocus/provider": ">=3.0.0",
    "prosemirror-model": ">=1.0.0",
    "prosemirror-state": ">=1.0.0",
    "prosemirror-transform": ">=1.0.0",
    "y-prosemirror": ">=1.0.0",
    "yjs": ">=13.0.0"
  },
  "peerDependenciesMeta": {
    "@hocuspocus/provider": { "optional": true },
    "y-prosemirror": { "optional": true },
    "yjs": { "optional": true }
  },
  "devDependencies": {
    "@hocuspocus/provider": "^3.4.4",
    "prosemirror-model": "^1.25.4",
    "prosemirror-state": "^1.4.4",
    "prosemirror-transform": "^1.11.0",
    "tsup": "^8.0.0",
    "typescript": "^5.4.0",
    "y-prosemirror": "^1.3.7",
    "yjs": "^13.6.30"
  }
}
