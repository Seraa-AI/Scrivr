{
  "name": "scrivr",
  "private": true,
  "version": "0.0.1",
  "packageManager": "pnpm@10.32.1",
  "description": "Scrivr — high-performance canvas-based document editor",
  "license": "Apache-2.0",
  "author": "Seraa AI <support@seraaai.co>",
  "repository": {
    "type": "git",
    "url": "https://github.com/Seraa-AI/Scrivr.git"
  },
  "homepage": "https://github.com/Seraa-AI/Scrivr#readme",
  "bugs": {
    "url": "https://github.com/Seraa-AI/Scrivr/issues"
  },
  "scripts": {
    "dev": "turbo dev --filter=@scrivr/demo",
    "dev:docs": "turbo dev --filter=@scrivr/docs --filter=@scrivr/server",
    "server": "turbo dev --filter=@scrivr/server",
    "build": "turbo build --filter='./packages/**'",
    "typecheck": "turbo typecheck",
    "test": "turbo test",
    "test:watch": "turbo test:watch",
    "test:ui": "vitest --ui",
    "coverage": "turbo test -- --coverage",
    "clean": "rm -rf {dist,node_modules} apps/*/{dist,node_modules} packages/*/{dist,node_modules}",
    "changeset": "changeset",
    "changeset:empty": "changeset --empty",
    "version-packages": "changeset version",
    "release": "pnpm build && pnpm --filter './packages/**' publish --access public --no-git-checks --provenance",
    "deploy:production:build": "turbo run deploy:production:build",
    "deploy:production:push": "turbo run deploy:production:push"
  },
  "devDependencies": {
    "@changesets/cli": "^2.30.0",
    "@vitest/coverage-v8": "^2.0.0",
    "@vitest/ui": "^2.0.0",
    "happy-dom": "^20.8.4",
    "turbo": "^2.8.20",
    "typescript": "^5.4.0",
    "vitest": "^2.0.0",
    "vitest-canvas-mock": "^1.1.3"
  }
}
