{
  "name": "scrivr",
  "private": true,
  "version": "0.0.1",
  "packageManager": "pnpm@10.32.1",
  "description": "Scrivr — high-performance canvas-based document editor",
  "license": "Apache-2.0",
  "author": "Seraa AI <hello@seraa.ai>",
  "repository": {
    "type": "git",
    "url": "https://github.com/Seraa-AI/Scrivr.git"
  },
  "homepage": "https://github.com/Seraa-AI/Scrivr#readme",
  "bugs": {
    "url": "https://github.com/Seraa-AI/Scrivr/issues"
  },
  "scripts": {
    "dev": "turbo dev --filter=@scrivr/demo",
    "dev:docs": "turbo dev --filter=@scrivr/docs",
    "server": "turbo dev --filter=@scrivr/server",
    "build": "turbo build --filter='./packages/**'",
    "typecheck": "turbo typecheck",
    "test": "turbo test",
    "test:watch": "turbo test:watch",
    "test:ui": "vitest --ui",
    "coverage": "turbo test -- --coverage",
    "clean": "rm -rf {dist,node_modules} apps/*/{dist,node_modules} packages/*/{dist,node_modules}"
  },
  "devDependencies": {
    "@vitest/coverage-v8": "^2.0.0",
    "@vitest/ui": "^2.0.0",
    "happy-dom": "^20.8.4",
    "turbo": "^2.8.20",
    "typescript": "^5.4.0",
    "vitest": "^2.0.0",
    "vitest-canvas-mock": "^1.1.3"
  }
}
