{
  "$schema": "https://turbo.build/schema.json",
  "ui": "tui",
  "tasks": {
    "build": {
      "dependsOn": ["^build"],
      "outputs": ["dist/**"]
    },
    "dev": {
      "dependsOn": ["^build"],
      "cache": false,
      "persistent": true
    },
    "test": {
      "dependsOn": ["^build"],
      "outputs": []
    },
    "test:watch": {
      "cache": false,
      "persistent": true
    },
    "typecheck": {
      "dependsOn": ["^build"]
    },
    "clean": {
      "cache": false,
      "persistent": true
    },
    "deploy:production:build": {
      "dependsOn": ["^build"],
      "outputs": [],
      "cache": false
    },
    "deploy:production:push": {
      "dependsOn": ["deploy:production:build"],
      "outputs": [],
      "cache": false
    }
  }
}
