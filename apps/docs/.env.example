# Scrivr docs app environment variables
#
# Copy this file to `.env` or `.env.local` in the same directory to configure
# local development. The .env file is gitignored — only .env.example is tracked.
#
# All client-side vars must be prefixed with VITE_ so Vite inlines them into
# the browser bundle. Server-side vars (not yet used in this app) would be
# read from process.env during SSR.
#
# Runtime vars are validated at app boot via apps/docs/src/lib/env.ts.
# Build-time flags (AI_ENABLED) are read directly from import.meta.env so
# Vite can tree-shake unreachable code paths at build time — see
# apps/docs/src/playground/Playground.tsx for the AI_ENABLED logic.

# ── Collaboration ─────────────────────────────────────────────────────────
# Enable the live collaboration backend. When "true", the playground connects
# to VITE_WS_URL and uses the Collaboration + CollaborationCursor extensions
# instead of the static demo document.
VITE_COLLAB=false

# WebSocket URL for the collaboration server. Only used when VITE_COLLAB=true.
# Default: ws://localhost:1235 (matches `pnpm server` / @scrivr/server).
VITE_WS_URL=ws://localhost:1235

# ── AI features (build-time flag) ─────────────────────────────────────────
# Enable the AiToolkit plugin, AI Chat Panel, and AI Suggestion Cards in
# production-like builds. In dev mode (`pnpm dev:docs`) AI is always on
# regardless of this flag.
#
# Usage: set this to "true" when you want to build a production bundle that
# includes the AI features — useful for testing the Docker image locally
# before deploying, or for self-hosting the docs app with AI enabled.
#
# Example:
#   VITE_AI_ENABLED=true pnpm build
#
# The public production deployment (scrivr.dev or equivalent) builds with
# this UNSET, so AI code is tree-shaken out of the bundle entirely. See
# docs/guides/ai-features.mdx for the full rationale.
#
# IMPORTANT: enabling this does NOT configure an Anthropic API key. You also
# need to run the AiToolkit plugin's own setup (typically passing your key
# via the plugin's configure options — see the AI features guide).
# VITE_AI_ENABLED=true
