# Scrivr collaboration server environment variables
#
# Copy this file to `.env` in the same directory to configure local development.
# The .env file is gitignored — only .env.example is tracked.

# ── Authentication ───────────────────────────────────────────────────────
# Token used to authenticate WebSocket connections. Clients must send a
# matching token via the Collaboration plugin's `token` option.
# When unset, all connections are allowed (no auth).
AUTH_TOKEN=
